# SwarmCom transport mode
SWARMCOM_TRANSPORT=local

# Matrix transport configuration
# Required only when SWARMCOM_TRANSPORT=matrix
MATRIX_HOMESERVER_URL=https://matrix-client.matrix.org
MATRIX_ACCESS_TOKEN=
MATRIX_USER_ID=@swarmcom-bot:example.com
MATRIX_PRIMARY_ROOM_ID=!replace-with-room-id:example.com
MATRIX_BOSS_ROOM_ID=!replace-with-boss-room-id:example.com
MATRIX_PEER_ROOM_ID=!replace-with-peer-room-id:example.com
MATRIX_WORKER_ROOM_ID=!replace-with-worker-room-id:example.com

# Per-channel shared secrets for signed messages
SWARMCOM_BOSS_CHANNEL_SECRET=replace-with-long-random-secret
SWARMCOM_PEER_CHANNEL_SECRET=replace-with-long-random-secret
SWARMCOM_WORKER_CHANNEL_SECRET=replace-with-long-random-secret

# SwarmCom runtime configuration
SWARMCOM_NETWORK_FILE=./swarmcom-network.json
SWARMCOM_STATUS_FILE=./swarmcom-status.json
SWARMCOM_HUMAN_STATUS_FILE=./STATUS.md
SWARMCOM_LOCAL_CHANNEL_DIR=./.swarmcom/channels